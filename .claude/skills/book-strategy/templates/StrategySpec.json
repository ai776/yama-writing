{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StrategySpec",
  "description": "書籍の戦略設計書。事業ゴール・ペルソナ・KPI・核心メッセージを定義する。",
  "type": "object",
  "required": ["goal", "persona", "kpi", "book_role", "core_message"],
  "properties": {
    "goal": {
      "type": "object",
      "properties": {
        "purpose": {
          "type": "string",
          "description": "最終目的（LINE登録→販売 / 採用 / ブランディング）"
        },
        "backend_product": {
          "type": "string",
          "description": "バックエンド商品"
        },
        "cta_flow": {
          "type": "string",
          "description": "CTA導線の設計"
        }
      },
      "required": ["purpose"]
    },
    "persona": {
      "type": "object",
      "properties": {
        "age_range": { "type": "string" },
        "occupation": { "type": "string" },
        "pain_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "values": { "type": "string" },
        "context": { "type": "string" }
      },
      "required": ["age_range", "pain_points"]
    },
    "kpi": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "metric": { "type": "string" },
          "target": { "type": "string" },
          "method": { "type": "string" }
        },
        "required": ["metric"]
      }
    },
    "book_role": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "description": "主たる役割" },
        "secondary": { "type": "string", "description": "副次的役割" }
      },
      "required": ["primary"]
    },
    "core_message": {
      "type": "string",
      "description": "この本で一つだけ伝えるなら何か"
    }
  }
}
