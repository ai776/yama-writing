{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BookSpec（統合版）",
  "description": "StrategySpec + ProductionSpec を統合した書籍仕様。全スキルが参照する。",
  "type": "object",
  "required": [
    "title",
    "author",
    "source_type",
    "strategy",
    "production"
  ],
  "properties": {
    "title": {
      "type": "string",
      "description": "書籍タイトル（仮）"
    },
    "author": {
      "type": "string",
      "description": "著者名"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "制作開始日"
    },
    "source_type": {
      "type": "string",
      "enum": ["seminar", "youtube", "reborn"],
      "description": "情報源タイプ"
    },
    "strategy": {
      "type": "object",
      "description": "Part A: 戦略（StrategySpec由来）",
      "required": ["goal", "persona", "core_message"],
      "properties": {
        "goal": {
          "type": "object",
          "properties": {
            "purpose": { "type": "string", "description": "最終目的" },
            "cta_flow": { "type": "string", "description": "CTA導線" },
            "backend_product": { "type": "string", "description": "バックエンド商品" }
          },
          "required": ["purpose"]
        },
        "persona": {
          "type": "object",
          "properties": {
            "age_range": { "type": "string" },
            "occupation": { "type": "string" },
            "pain_points": { "type": "array", "items": { "type": "string" } },
            "values": { "type": "string" },
            "context": { "type": "string" }
          },
          "required": ["age_range", "pain_points"]
        },
        "kpi": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "target": { "type": "string" }
            }
          }
        },
        "core_message": {
          "type": "string",
          "description": "この本で一つだけ伝えるなら何か"
        },
        "book_role": {
          "type": "string",
          "description": "ファネル内での書籍の役割"
        }
      }
    },
    "production": {
      "type": "object",
      "description": "Part B: 制作条件（ProductionSpec由来）",
      "required": ["tone", "volume", "citation_format"],
      "properties": {
        "tone": {
          "type": "object",
          "properties": {
            "base": { "type": "string", "description": "基本文体" },
            "colloquial_level": {
              "type": "string",
              "enum": ["low", "medium", "high"],
              "description": "口語許容度"
            },
            "banned_expressions": {
              "type": "array",
              "items": { "type": "string" },
              "description": "著者固有の禁止表現"
            }
          },
          "required": ["base", "colloquial_level"]
        },
        "volume": {
          "type": "object",
          "properties": {
            "total_chars": { "type": "integer", "description": "総文字数目安" },
            "chapter_count": { "type": "integer", "description": "章数" },
            "chars_per_chapter": { "type": "integer", "description": "章ごと文字数予算" },
            "preface_chars": { "type": "integer", "description": "まえがき文字数" },
            "afterword_chars": { "type": "integer", "description": "あとがき文字数" }
          },
          "required": ["total_chars", "chapter_count"]
        },
        "visuals": {
          "type": "object",
          "properties": {
            "frequency": { "type": "string", "description": "挿入頻度" },
            "types": { "type": "array", "items": { "type": "string" } },
            "placement_rule": { "type": "string", "description": "挿入位置ルール" },
            "caption_style": { "type": "string", "description": "キャプション形式" }
          }
        },
        "citation_format": {
          "type": "object",
          "properties": {
            "style": { "type": "string", "description": "引用スタイル" },
            "timestamp_required": { "type": "boolean" },
            "speaker_required": { "type": "boolean" }
          },
          "required": ["style"]
        }
      }
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "operational_rules": {
      "type": "object",
      "properties": {
        "single_file": { "type": "boolean", "default": true },
        "source_strict": { "type": "boolean", "default": true },
        "three_stage_review": { "type": "boolean", "default": true },
        "no_citation_in_body": { "type": "boolean", "default": true }
      }
    }
  }
}
